# API base URL consumed by the browser.
# Local option (with API proxy rewrite): NEXT_PUBLIC_API_URL=/api
# Production option (separate API host): NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=/api

# Optional server-side rewrite target for Next.js.
# Set in local development if you want /api to proxy to backend directly.
# API_PROXY_TARGET=http://localhost:5000
