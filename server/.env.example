PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
JWT_ACCESS_SECRET=change_me_unique_levis_access
JWT_REFRESH_SECRET=change_me_unique_levis_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Paystack: use LIVE keys for real charges, TEST keys for test cards.
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_AMOUNT_PLATINUM=50000
PAYSTACK_AMOUNT_SILVER=100000
PAYSTACK_AMOUNT_GOLD=300000
PAYSTACK_AMOUNT_DIAMOND=500000
# OPay Cashier (set these to enable OPay checkout fallback/primary)
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_MERCHANT_ID=
OPAY_WEBHOOK_SECRET=
OPAY_COUNTRY=NG
OPAY_API_BASE=https://liveapi.opaycheckout.com
OPAY_PAY_METHOD=
BILLING_DEFAULT_PROVIDER=paystack
BILLING_PROVIDER_TOKEN=
ADMIN_UNLOCK_PHRASE=diamonds-open
ADMIN_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1
# Durable storage backend: auto | kv | file | memory
STORE_BACKEND=auto
# Vercel KV / Upstash Redis REST (required for persistence on serverless)
KV_REST_API_URL=
KV_REST_API_TOKEN=
STORE_KV_KEY=unique-levis:store-snapshot:v1
