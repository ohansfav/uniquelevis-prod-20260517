PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
JWT_ACCESS_SECRET=change_me_unique_levis_access
JWT_REFRESH_SECRET=change_me_unique_levis_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Flutterwave v3 credentials
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
# Optional but recommended for webhook validation (Dashboard -> Webhooks -> Secret Hash)
FLUTTERWAVE_WEBHOOK_SECRET_HASH=
FLUTTERWAVE_API_BASE=https://api.flutterwave.com
# Optional comma-separated options e.g. card,banktransfer,ussd
FLUTTERWAVE_PAYMENT_OPTIONS=
BILLING_CURRENCY=NGN
BILLING_AMOUNT_PLATINUM=50000
BILLING_AMOUNT_SILVER=100000
BILLING_AMOUNT_GOLD=300000
BILLING_AMOUNT_DIAMOND=500000
BILLING_DEFAULT_PROVIDER=flutterwave
BILLING_PROVIDER_TOKEN=
ADMIN_UNLOCK_PHRASE=diamonds-open
ADMIN_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1
# Durable storage backend: auto | kv | file | memory
STORE_BACKEND=auto
# Vercel KV / Upstash Redis REST (required for persistence on serverless)
KV_REST_API_URL=
KV_REST_API_TOKEN=
STORE_KV_KEY=unique-levis:store-snapshot:v1
