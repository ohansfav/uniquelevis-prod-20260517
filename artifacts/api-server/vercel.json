{
  "version": 2,
  "buildCommand": "corepack pnpm --filter @workspace/api-server build",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/[...slug].js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...slug].js"
    },
    {
      "src": "/api",
      "dest": "/api/index.js"
    }
  ]
}
