{
  "framework": "vite",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/unique-levis build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
